# GEMINI_API_KEY: Required for content intelligence and summary generation.
# Configure this via your environment variables or local deployment secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this host is running.
# Injected at runtime or specified for local configurations.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
