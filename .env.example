# Firebase client configuration for the Vite frontend.
# Do not commit real Firebase values. Configure these in local or hosting env settings.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin configuration for Vercel serverless API routes.
# Never expose these as VITE_* variables and never commit real service account values.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# GEMINI_API_KEY: Planned for the next backend/AI summarization phase.
# The current refresh API does not use this value yet.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Planned deployment URL for later callbacks, links, and API configuration.
# The current frontend prototype does not require this value to run.
APP_URL="MY_APP_URL"
