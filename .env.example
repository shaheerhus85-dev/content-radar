# Firebase client configuration for the Vite frontend.
# Do not commit real Firebase values. Configure these in local or hosting env settings.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin configuration for Vercel serverless API routes.
# Never expose these as VITE_* variables and never commit real service account values.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Gemini server-side AI insight generation.
# Never expose this as a VITE_* variable.
GEMINI_API_KEY=
GEMINI_MODEL=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_PROVIDER_ORDER=gemini,groq
DEBUG_SECRET=

# APP_URL: Planned deployment URL for later callbacks, links, and API configuration.
# The current frontend prototype does not require this value to run.
APP_URL=
